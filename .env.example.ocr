# ============================================
# OCR 手写识别配置
# ============================================

# 选择 OCR 服务商（可选：tencent, baidu, aliyun, google）
# 默认：tencent
OCR_PROVIDER=tencent

# ============================================
# 腾讯云 OCR 配置
# ============================================

# 腾讯云 Secret ID
# 获取地址：https://console.cloud.tencent.com/cam/capi
TENCENT_OCR_SECRET_ID=your_secret_id_here

# 腾讯云 Secret Key
TENCENT_OCR_SECRET_KEY=your_secret_key_here

# 腾讯云地域（可选，默认 ap-guangzhou）
# 可选值：ap-guangzhou, ap-shanghai, ap-beijing 等
TENCENT_OCR_REGION=ap-guangzhou

# ============================================
# 百度云 OCR 配置
# ============================================

# 百度云 API Key
# 获取地址：https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_OCR_API_KEY=your_api_key_here

# 百度云 Secret Key
BAIDU_OCR_SECRET_KEY=your_secret_key_here

# ============================================
# 阿里云 OCR 配置
# ============================================

# 阿里云 Access Key ID
# 获取地址：https://ram.console.aliyun.com/manage/ak
ALIYUN_OCR_ACCESS_KEY_ID=your_access_key_id_here

# 阿里云 Access Key Secret
ALIYUN_OCR_ACCESS_KEY_SECRET=your_access_key_secret_here

# 阿里云 OCR 端点（可选）
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# ============================================
# Google Cloud OCR 配置
# ============================================

# Google Cloud API Key
GOOGLE_OCR_API_KEY=your_google_api_key_here
