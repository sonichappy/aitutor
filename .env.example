# 数据库连接（可选，当前使用模拟数据）
DATABASE_URL="postgresql://user:password@localhost:5432/aitutor"

# ============================================
# AI 模型配置
# ============================================

# 选择 AI 提供商: deepseek | dashscope | openai | anthropic | gemini
AI_PROVIDER=dashscope

# --- DeepSeek 配置 ---
DEEPSEEK_API_KEY=sk-246cd7816f0948689a258dc05b08bf10
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 通义千问配置 ---
DASHSCOPE_API_KEY=sk-ba9f4388b94a4c059cf2567221ef4ca6
# 文本对话模型：qwen-plus、qwen-turbo、qwen-max
DASHSCOPE_MODEL=qwen3.5-plus
# 图像识别模型（试卷OCR）：qwen-vl-plus、qwen-vl-max
DASHSCOPE_VL_MODEL=qwen3.5-plus

# --- OpenAI 配置 ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- Anthropic Claude 配置 ---
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Gemini 配置 ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# 代理配置（国内访问 Google API 需要）
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# ============================================
# 可选配置
# ============================================

# AI 生成参数
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1500

# 对话历史保留条数
CHAT_HISTORY_LIMIT=10
