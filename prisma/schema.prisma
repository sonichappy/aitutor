// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id              String            @id @default(cuid())
  name            String?
  email           String?           @unique
  passwordHash    String?
  grade           Int               // 年级 (7-9 初中, 10-12 高中)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessions        Session[]
  questions       Question[]
  knowledgePoints KnowledgePoint[]
  exams           Exam[]
  wrongQuestions  WrongQuestion[]  // 错题库
  englishWords    EnglishWord[]    // 英语单词本
  englishGrammars EnglishGrammar[] // 英语语法
}

// 学习会话
model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String    // 科目 (数学/物理/化学/英语等)
  startTime DateTime  @default(now())
  endTime   DateTime?
  messages  Message[]
}

// 对话消息
model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user/assistant
  content   String   @db.Text
  createdAt DateTime @default(now())
}

// 练习题记录
model Question {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String   // 科目
  content     String   @db.Text  // 题目内容
  userAnswer  String?  @db.Text  // 学生答案
  isCorrect   Boolean? // 是否正确
  knowledgePoints String[] // 关联的知识点
  difficulty  Int?     // 难度 (1-5)
  createdAt   DateTime @default(now())
}

// 知识点掌握情况
model KnowledgePoint {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String   // 知识点名称
  subject       String   // 科目
  masteryLevel  Float    @default(0) // 掌握程度 (0-1)
  practiceCount Int      @default(0) // 练习次数
  correctCount  Int      @default(0) // 正确次数
  correctRate   Float    @default(0) // 正确率
  lastPracticed DateTime? // 最后练习时间
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, name, subject])
}

// 题库（用于RAG检索）
model QuestionBank {
  id            String   @id @default(cuid())
  subject       String   // 科目
  content       String   @db.Text // 题目内容
  answer        String   @db.Text // 答案
  explanation   String?  @db.Text // 解析
  knowledgePoints String[] // 关联的知识点
  difficulty    Int      // 难度 (1-5)
  grade         Int      // 适用年级
  createdAt     DateTime @default(now())
}

// ============================================
// 试卷分析相关模型
// ============================================

// 试卷
model Exam {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String   // 科目
  examType     String   // 试卷类型: 期中/期末/月考/练习/模拟
  examDate     DateTime @default(now()) // 考试日期
  title        String?  // 试卷标题
  totalScore   Float    // 总分
  obtainedScore Float?  // 得分
  status       String   @default("uploading") // uploading/parsing/parsed/reviewing/analyzing/completed
  content      String?  @db.Text // 原始试卷内容
  imageUrl     String?  // 试卷图片URL
  summary      String?  @db.Text // AI生成的摘要
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  questions    ExamQuestion[]
  analysis     ExamAnalysis?

  @@index([userId, createdAt])
}

// 试卷题目
model ExamQuestion {
  id              String   @id @default(cuid())
  examId          String
  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionNumber  Int      // 题号
  type            String   // 题型: choice/fill/answer/calculation/essay
  content         String   @db.Text // 题目内容
  options         String?  @db.Text // 选项（JSON字符串）
  knowledgePoints String[] // 知识点
  difficulty      Int      @default(3) // 难度 1-5
  score           Float    // 分值
  correctAnswer   String?  @db.Text // 正确答案
  userAnswer      String?  @db.Text // 用户答案
  isCorrect       Boolean? // 是否正确
  isSkipped       Boolean  @default(false) // 是否未做
  isWrongQuestion Boolean  @default(false) // 是否错题
  // AI分析结果
  errorAnalysis  String?  @db.Text // 错误原因分析
  weakPoints      String[]  // 薄弱知识点
  improvement     String?  @db.Text // 改进建议
  aiExplanation   String?  @db.Text // AI详细解析
  explanation      String?  @db.Text // 题目解析
  ocrBoundingInfo  String? @db.Text // OCR识别的位置信息
  imageUrl        String?  // 题目截图URL
  createdAt       DateTime @default(now())

  @@index([examId, questionNumber])
}

// 试卷分析结果
model ExamAnalysis {
  id              String   @id @default(cuid())
  examId          String   @unique
  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  summary         String   @db.Text // 分析摘要
  knowledgeAnalysis String? @db.Text // 知识点分析（JSON）
  weakPoints      String[] // 薄弱知识点
  strongPoints    String[] // 优势知识点
  suggestions     String[] // 学习建议
  aiReport        String?  @db.Text // AI生成的详细报告
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// 错题库模型
// ============================================

// 错题记录
model WrongQuestion {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         String   // 科目
  originalExamId   String?  // 原试卷ID
  originalQuestionId String? // 原题目ID

  // 题目信息
  type            String   // 题型: choice/fill/answer/etc
  content         String   @db.Text // 题目内容
  options         String?  @db.Text // 选项
  correctAnswer   String   @db.Text // 正确答案
  userAnswer      String   @db.Text // 用户错误答案

  // 分析信息
  knowledgePoints String[] @default([]) // 知识点
  difficulty      Int      @default(3) // 难度

  // 错误分析
  errorReason     String?  @db.Text // 错误原因分类
  errorAnalysis   String?  @db.Text // AI分析的错误原因
  weakPoints      String[] @default([]) // 薄弱知识点
  improvement     String?  @db.Text // 改进建议
  aiExplanation   String?  @db.Text // AI详细解析

  // 复习记录
  reviewCount     Int      @default(0) // 复习次数
  masteredAt      DateTime? // 掌握时间
  nextReviewAt   DateTime? // 下次复习时间 (艾宾浩斯遗忘曲线)

  // 状态
  status          String   @default("active") // active/mastered/archived

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, subject, status])
  @@index([userId, nextReviewAt])
}

// 错题标签
model WrongQuestionTag {
  id            String   @id @default(cuid())
  name          String   @unique // 标签名称
  color         String   // 颜色
  icon          String?  // 图标
  description   String?  // 描述
  createdAt     DateTime @default(now())
}

// ============================================
// 学科专栏相关模型
// ============================================

// 英语单词本
model EnglishWord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  word            String   // 单词
  phonetic        String?  // 音标
  partOfSpeech    String?  // 词性 (noun/verb/adj/adv...)
  meanings        String   @db.Text // 释义 (JSON数组)
  definitions     String?  @db.Text // 英文释义
  exampleSentences String? @db.Text // 例句 (JSON数组)

  // 分类和标签
  category         String?  // 分类：考试/四六级/托福/雅思/日常
  tags            String[]  // 标签
  source          String?  // 来源

  // 学习状态
  masteryLevel    Float    @default(0) // 掌握程度 0-1
  reviewCount     Int      @default(0) // 复习次数
  correctCount    Int      @default(0) // 正确次数

  // 记忆曲线
  nextReviewAt    DateTime? // 下次复习时间
  lastReviewedAt  DateTime? // 上次复习时间
  easeFactor      Float    @default(2.5) // 记忆因子 (SM2算法)
  interval        Int      @default(0) // 当前间隔（天）

  status          String   @default("learning") // learning/mastered/archived

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, word])
  @@index([userId, nextReviewAt])
  @@index([userId, category])
}

// 英语语法点
model EnglishGrammar {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String   // 语法点标题
  category        String   // 分类：时态/语态/从句/非谓语/虚拟语气等
  level           String   // 难度：初级/中级/高级

  // 内容
  explanation     String   @db.Text // 语法讲解
  formulas        String?  @db.Text // 公式/结构
  examples        String   @db.Text // 例句 (JSON数组)
  commonErrors    String?  @db.Text // 常见错误
  notes           String?  @db.Text // 笔记

  // 关联
  relatedWords    String[] // 相关单词

  // 学习状态
  masteryLevel    Float    @default(0) // 掌握程度
  practiceCount   Int      @default(0) // 练习次数

  status          String   @default("active") // active/archived

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, category])
  @@index([userId, level])
}
